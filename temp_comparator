`timescale 1ns/1ps
module temp_comparator(
    input  [7:0] temp,
    output reg normal,
    output reg warning,
    output reg critical
);

always @(*) begin
    normal   = 0;
    warning  = 0;
    critical = 0;

    if (temp < 45)
        normal = 1;
    else if (temp < 60)
        warning = 1;
    else
        critical = 1;
end

endmodule
